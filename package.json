{
  "name": "nova",
  "version": "0.1.0",
  "description": "Nova - Desktop AI Chat Interface",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "generate-icon": "node scripts/generate-icon.mjs",
    "build": "tsc && vite build",
    "dist": "npm run build && electron-builder --publish never",
    "release": "npm run dist && node scripts/generate-release-hash.js",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.nova.app",
    "productName": "Nova",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ]
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "sharp": "^0.34.5",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
